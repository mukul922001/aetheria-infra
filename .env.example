# .env.example — template for local secrets/config.
# COPY this file to ".env" and adjust if you like:   cp .env.example .env
# The real .env is git-ignored (never commit secrets — 12-Factor rule).

# --- PostgreSQL ---
POSTGRES_USER=aetheria
POSTGRES_PASSWORD=aetheria_dev_pw
POSTGRES_DB=aetheria

# --- RabbitMQ ---
RABBITMQ_USER=aetheria
RABBITMQ_PASSWORD=aetheria_dev_pw

# --- MinIO (S3-compatible storage) ---
MINIO_ROOT_USER=aetheria
MINIO_ROOT_PASSWORD=aetheria_dev_pw
